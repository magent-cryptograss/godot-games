# Helper: render a pixel grid with a given palette at position
static func draw_sprite(canvas: CanvasItem, grid: Array, palette: Array, x: float, y: float, flip_h: bool = false) -> void:
	var h = grid.size()
	if h == 0: return
	var w = grid[0].size()
	for py in range(h):
		for px in range(w):
			var idx = grid[py][px]
			if idx == 0: continue
			if idx >= palette.size(): continue
			var draw_x = x + (w - 1 - px if flip_h else px) - w / 2
			var draw_y = y + py - h
			canvas.draw_rect(Rect2(draw_x, draw_y, 1, 1), palette[idx])
